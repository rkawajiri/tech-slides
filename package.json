{
  "name": "tech-slides",
  "private": true,
  "scripts": {
    "build": "for dir in $(find . -maxdepth 1 -regex './[0-9].*' -type d); do marp \"$dir/slides.md\" -o \"dist/$(basename $dir)/index.html\"; done",
    "preview": "marp --preview",
    "pdf": "marp --pdf",
    "new": "bash scripts/new-slide.sh",
    "diagrams": "for f in 2026-03-19/diagrams/*.mmd; do mmdc -i \"$f\" -o \"${f%.mmd}.svg\" -t neutral; done",
    "check": "node scripts/check-overflow.mjs",
    "textlint": "textlint '**/*.md'",
    "textlint:fix": "textlint --fix '**/*.md'"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4",
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "playwright": "^1.58.2",
    "textlint": "^15.5.2",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2"
  }
}
